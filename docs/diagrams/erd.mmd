        int id PK
        string name
        string town
        string municipality
        float latitude
        float longitude
    }

    APPLICATIONS {
        int id PK
        int opportunity_id FK
        string status
        date deadline
        date submitted_at
        string pitch_number
    }

    OPERATIONS {
        int id PK
        int opportunity_id FK
        int application_id FK
        string status
        datetime setup_start_at
        datetime teardown_end_at
        string pitch_number
    }

    OPERATION_OUTCOMES {
        int id PK
        int operation_id FK
        bool attended
        float revenue_eur
        float costs_eur
        float profit_eur
        bool attend_again
    }

    CALENDAR_FEEDS {
        int id PK
        string name
        string feed_type
        string filter_json
