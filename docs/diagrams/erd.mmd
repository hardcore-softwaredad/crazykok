    OPPORTUNITY_SERIES {
        int id PK
        string name
        string category
        string recurring_pattern
        string official_website_url
    }

    OPPORTUNITIES {
        int id PK
        int opportunity_series_id FK
        int venue_id FK
        int organiser_id FK
        string title
        date start_date
        date end_date
        string research_status
        string application_status_summary
        float profit_score
    }

