# Runtime mode. Keep the committed default non-production.
APP_ENV=development

# Public virtual hosts served by the Docker web gateway.
# For cloud hosting, override with crazykok.com/app.crazykok.com/api.crazykok.com.
APP_DOMAIN=crazykok.local
APP_DOMAIN_ALIAS=app.crazykok.local
API_DOMAIN=api.crazykok.local
DOCS_DOMAIN=docs.crazykok.local
API_DOCS_DOMAIN=api-docs.crazykok.local

# Filesystem-backed ADR authoring is local-only and bypasses Nginx.
ADR_AUTHORING_ENABLED=true
ADR_DIRECTORY=/app/docs/adr
DOCS_ORIGIN=https://docs.crazykok.local
API_DOCS_ORIGIN=https://api-docs.crazykok.local

# Comma-separated browser origins allowed to call the API directly.
CORS_ALLOWED_ORIGINS=https://crazykok.local,https://app.crazykok.local,https://api-docs.crazykok.local

# Host ports used by Docker Compose. Port 80 redirects to HTTPS.
WEB_PORT=80
HTTPS_PORT=443
API_PORT=8000

# Hypermedia URLs derive from trusted local proxy headers. Set a complete
# canonical API root such as https://api.example.com/v1 when deployment
# topology does not preserve forwarded host, scheme, and prefix information.
TRUST_PROXY_HEADERS=true
PUBLIC_API_BASE_URL=

# The local SQLite database is stored in the api-data Docker volume.
DATABASE_URL=sqlite:////data/app.db

# Origin for straight-line distance shown in the planning workspace.
PLANNING_HOME_LATITUDE=52.6627
PLANNING_HOME_LONGITUDE=6.8847

# Venue document and photo storage. Keep this on the same backed-up data volume.
ATTACHMENT_ROOT=/data/attachments
MAX_ATTACHMENT_BYTES=20971520
